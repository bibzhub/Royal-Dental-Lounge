# Royal Dental Lounge ??Environment Configuration
# Copy this file to .env and fill in your credentials

# ?А?А?А WhatsApp Business API ?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А
# Get these from Meta Business Manager:
# https://developers.facebook.com/apps/
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_ACCESS_TOKEN=your_whatsapp_access_token
WA_VERIFY_TOKEN=royal_dental_lounge_2025
WA_API_VERSION=v18.0

# ?А?А?А Twilio (Alternative WA provider) ?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WA_NUMBER=whatsapp:+14155238886

# ?А?А?А Database ?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А?А
